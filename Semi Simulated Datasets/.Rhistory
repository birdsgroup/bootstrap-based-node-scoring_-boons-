packageVersion("WebGestaltR")
library(splatter)
BiocManager::install("splatter")
library(splatter)
params <- newSplatParams()
params <- setParams(params, nGenes = 100, batchCells = 50)
params <- setParams(params, bcv.common = 0.5, dropout.type = "experiment")
sim <- splatSimulate(params)
expression_matrix <- counts(sim)
View(expression_matrix)
